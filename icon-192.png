    {
      "id": "hegra",
      "name_en": "Hegra (Mada'in Salih)",
      "name_ar": "الحِجر (مدائن صالح)",
      "category": "heritage",
      "lat": 26.7917, "lng": 37.9542,
      "rating": 4.9, "duration": "3-4 hrs", "price": 95,
      "desc_en": "Saudi Arabia's first UNESCO World Heritage Site: a Nabataean necropolis with over 110 rock-cut tombs and elaborately carved facades, built by the same civilization as Petra. Visited via official guided tour from Winter Park Visitor Center.",
      "desc_ar": "أول موقع سعودي مُدرج في قائمة اليونسكو للتراث العالمي: مقبرة نبطية تضم أكثر من ١١٠ مقابر منحوتة في الصخر بواجهات بديعة، بناها النبطيون أنفسهم بناة البتراء. تُزار عبر جولة رسمية من مركز زوّار وينتر بارك.",
      "tip_en": "Self-driving is not allowed — visit only via an organised tour (from SAR 95, ~2 hrs). Pre-book; free parking at the South Gate. Don't miss the Hinat exhibition at the Visitor Centre.",
      "tip_ar": "القيادة الذاتية ممنوعة — الزيارة بجولة منظّمة فقط (من ٩٥ ريال، ساعتان). احجز مسبقاً؛ موقف مجاني بالبوابة الجنوبية. لا تفوّت معرض «هناة» في مركز الزوّار.",
      "tour_stops": ["Jabal Ithlib", "Jabal Banat", "Tomb of Lihyan son of Kuza", "Jabal Ahmar", "Jabal Khuraymat", "Handcraft Pavilion"],
      "directions": "https://maps.app.goo.gl/G96grhKnUZE2jiYHA",
      "official": "https://www.experiencealula.com/en/places-to-go/hegra",
      "wiki": "Hegra (Mada'in Salih)"
    },
    {
      "id": "elephant_rock",
      "name_en": "Elephant Rock (Jabal AlFil)",
      "name_ar": "صخرة الفيل (جبل الفيل)",
      "category": "heritage",
      "lat": 26.6469, "lng": 38.0186,
      "rating": 4.8, "duration": "1-2 hrs", "price": 0,
      "desc_en": "A 52-meter sandstone monolith naturally carved by wind and water into the unmistakable shape of an elephant. One of the most photographed landmarks in AlUla, with open-air cafes and seating at its base.",
      "desc_ar": "كتلة صخرية رملية ارتفاعها ٥٢ متراً، نحتتها الرياح والمياه على هيئة فيل واضحة المعالم. من أكثر معالم العلا تصويراً، وحولها مقاهٍ ومجالس في الهواء الطلق.",
      "tip_en": "Come at sunset or after dark when it's lit up and lively; cafes open roughly 6 PM-3 AM.",
      "tip_ar": "تعال عند الغروب أو بعد حلول الظلام حين يُضاء ويزدحم؛ المقاهي تفتح تقريباً ٦ مساءً حتى ٣ فجراً.",
      "official": "https://www.experiencealula.com/en/things-to-do/nature-and-wildlife/elephant-rock",
      "wiki": "Elephant Rock (Saudi Arabia)"
    },
    {
      "id": "old_town",
      "name_en": "AlUla Old Town",
      "name_ar": "بلدة العلا القديمة",
      "category": "heritage",
      "lat": 26.6186, "lng": 37.9214,
      "rating": 4.7, "duration": "2-3 hrs", "price": 0,
      "desc_en": "A 900-house mudbrick labyrinth dating back over seven centuries, with 400 shops and five town squares, topped by a 10th-century citadel overlooking the valley. Restored alleys now hold craft shops, cafes and restaurants.",
      "desc_ar": "متاهة من الطين تضم نحو ٩٠٠ منزل يعود تاريخها لأكثر من سبعة قرون، مع ٤٠٠ محل وخمس ساحات، تعلوها قلعة من القرن العاشر تطل على الوادي. أزقتها المرمّمة تضم اليوم محلات حرف ومقاهي ومطاعم.",
      "tip_en": "Visit in late afternoon for golden light, then stay for dinner. Walk Market Street toward AlJadidah.",
      "tip_ar": "زرها بعد العصر للضوء الذهبي، ثم ابقَ للعشاء. امشِ في شارع السوق نحو الجديدة.",
      "official": "https://www.experiencealula.com/en/things-to-do/heritage-and-history/alula-old-town",
      "wiki": "AlUla"
    },
    {
      "id": "dadan",
      "name_en": "Dadan",
      "name_ar": "دادان",
      "category": "heritage",
      "lat": 26.6206, "lng": 37.9558,
      "rating": 4.7, "duration": "1-2 hrs", "price": 75,
      "desc_en": "Capital of the ancient Dadan and Lihyan kingdoms over 2,000 years ago, famous for the 'lion tombs' carved high into the cliff face and a key trade hub on the incense route.",
      "desc_ar": "عاصمة مملكتي دادان ولحيان القديمتين قبل أكثر من ألفي عام، تشتهر بـ«مقابر الأسود» المنحوتة عالياً في الجرف، وكانت محطة تجارية رئيسة على طريق البخور.",
      "tip_en": "Combine with Jabal Ikmah nearby; both are part of the Dadan experience.",
      "tip_ar": "اجمعها مع جبل عكمة القريب؛ كلاهما ضمن تجربة دادان.",
      "official": "https://www.experiencealula.com/en/things-to-do/heritage-and-history/dadan",
      "wiki": "Dadan"
    },
    {
      "id": "jabal_ikmah",
      "name_en": "Jabal Ikmah",
      "name_ar": "جبل عكمة",
      "category": "heritage",
      "lat": 26.6469, "lng": 37.9447,
      "rating": 4.6, "duration": "1 hr", "price": 0,
      "desc_en": "An open-air library of thousands of inscriptions in Dadanitic, Thamudic, Aramaic, Minaic and Nabataean scripts carved into a desert canyon — a UNESCO Memory of the World listing.",
      "desc_ar": "مكتبة في الهواء الطلق تضم آلاف النقوش بالخطوط الدادانية والثمودية والآرامية والمعينية والنبطية محفورة في وادٍ صحراوي — مُدرجة في سجل ذاكرة العالم لليونسكو.",
      "tip_en": "Go early; the canyon gets hot. Free entry.",
      "tip_ar": "اذهب مبكراً؛ الوادي يشتد حره. الدخول مجاني.",
      "official": "https://www.experiencealula.com/en/things-to-do/heritage-and-history/jabal-ikmah",
      "wiki": "Jabal Ikmah"
    },
    {
